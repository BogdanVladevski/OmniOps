#!/bin/sh
# Remove unwanted co-author trailers from commit messages.
# Enable once per clone: git config core.hooksPath .githooks

if [ -f "$1" ]; then
  sed -i.bak '/cursoragent@cursor\.com/d' "$1"
  sed -i.bak '/Co-authored-by: Cursor/d' "$1"
  sed -i.bak '/Made-with: Cursor/d' "$1"
  rm -f "$1.bak"
fi
