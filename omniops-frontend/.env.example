# Copy to .env and adjust if your API runs on a different host/port.
# Physical device: use your machine's LAN IP instead of localhost.
EXPO_PUBLIC_API_URL=http://localhost:5031

# Required when the API has JWT_REQUIRE_AUTHENTICATION=true.
# In Development, obtain a token: POST http://localhost:5031/api/auth/token with body {"scopes":["vehicle:read"]}
EXPO_PUBLIC_API_TOKEN=