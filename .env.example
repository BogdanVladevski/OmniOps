# ==============================================================================
# OmniOps Core Infrastructure Environment Configuration
# Copy to .env and adjust values for your local environment.
# ==============================================================================

# ASP.NET Core Runtime Environment
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5031

# PostgreSQL Data Store Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123
POSTGRES_DB=OmniOps
DB_PORT=5433
DB_HOST=127.0.0.1
DB_CONNECTION_STRING=Host=127.0.0.1;Port=5433;Database=OmniOps;Username=postgres;Password=123

# Redis Cache Cluster Config
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_CONNECTION_STRING=127.0.0.1:6379,abortConnect=false

# Distributed Message Broker (Apache Kafka) Config
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_CONSUMER_GROUP_ID=omniops-telemetry-group
KAFKA_MAIN_TOPIC=fleet-telemetry
KAFKA_EVENTS_TOPIC=fleet-telemetry-events
KAFKA_DLQ_TOPIC=fleet-telemetry-dlq

# Client Web / Mobile Security Origins
ALLOWED_CORS_ORIGINS=http://localhost:19006,http://localhost:3000

# JWT Authentication (set JWT_REQUIRE_AUTHENTICATION=true for production-like local testing)
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
JWT_ISSUER=OmniOps
JWT_AUDIENCE=OmniOps.Clients
JWT_EXPIRATION_MINUTES=60
JWT_REQUIRE_AUTHENTICATION=false

# Simulate endpoint rate limiting (per client IP)
SIMULATE_RATE_LIMIT_PERMIT_LIMIT=10
SIMULATE_RATE_LIMIT_WINDOW_SECONDS=60

# Structured logging (Serilog)
SERILOG_MINIMUM_LEVEL=Information

# Prometheus metrics scrape endpoint (GET /metrics)
PROMETHEUS_METRICS_ENABLED=true

# Expo Frontend (optional)
EXPO_PUBLIC_API_URL=http://localhost:5031
# Required when JWT_REQUIRE_AUTHENTICATION=true — obtain via POST /api/auth/token in Development
EXPO_PUBLIC_API_TOKEN=
