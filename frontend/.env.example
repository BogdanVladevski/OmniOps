# Copy to .env and adjust if your API runs on a different host/port.
# localhost is fine — Expo Go on a phone auto-rewrites to your PC's LAN IP (see utils/api.js).
# If auto-resolve fails, set your LAN IP explicitly, e.g. http://192.168.1.173:5031
EXPO_PUBLIC_API_URL=http://localhost:5031

# Comma-separated vehicle IDs — should match backend FLEET_VEHICLE_IDS
EXPO_PUBLIC_FLEET_VEHICLES=Truck-001,Truck-002,Truck-003

# Required when the API has JWT_REQUIRE_AUTHENTICATION=true.
# In Development, obtain a token: POST http://localhost:5031/api/auth/token with body {"scopes":["vehicle:read"]}
EXPO_PUBLIC_API_TOKEN=